modules = ["python-3.12", "nodejs-22"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd back && uv sync --frozen && ([ -f .env ] || cp .env.example .env) && uv run uvicorn main:app --reload --port 8000"
waitForPort = 8000

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd front && ([ -f node_modules/.package-lock.json ] && diff -q package-lock.json node_modules/.package-lock.json > /dev/null 2>&1 || npm install) && npm run dev -- --host 0.0.0.0 --port 5173"
waitForPort = 5173

[[workflows.workflow]]
name = "Package"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/package.sh"

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000
exposeLocalhost = true

[agent]
expertMode = true

# Non-secret Azure OpenAI defaults — committed, auto-applied on remix.
# Override via the Replit Configurations pane if your resource differs.
# The 2 sensitive values (KEY, ENDPOINT) must still be set in Secrets or
# linked from your Replit Account Secrets.
[env]
AZURE_OPENAI_DEPLOYMENT = "gpt-5-chat"
AZURE_OPENAI_API_VERSION = "2025-01-01-preview"
