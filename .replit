modules = ["python-3.12", "nodejs-22"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd back && uv sync --frozen && ([ -f .env ] || cp .env.example .env) && uv run uvicorn main:app --reload --port 8000"
waitForPort = 8000

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd front && ([ -f node_modules/.package-lock.json ] && diff -q package-lock.json node_modules/.package-lock.json > /dev/null 2>&1 || npm install) && npm run dev -- --host 0.0.0.0 --port 5173"
waitForPort = 5173

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 5173
externalPort = 80
